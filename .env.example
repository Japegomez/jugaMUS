# Copia este archivo a `.env.local` y rellena con las claves del proyecto.
# Expo solo expone variables con prefijo EXPO_PUBLIC_ al bundle.

# Supabase (Dashboard → Settings → API)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_anon_or_publishable_key

# GitHub Actions (sentry-health): añade los mismos valores como *secrets* del repo
# EXPO_PUBLIC_SUPABASE_URL, EDGE_CRON_SECRET, SENTRY_AUTH_TOKEN

# Sentry (Project → Settings → Client Keys; UE suele usar ingest.de.sentry.io)
EXPO_PUBLIC_SENTRY_DSN=https://YOUR_KEY@oXXXXXX.ingest.de.sentry.io/XXXXXXX

# PostHog (eu.posthog.com → Project → Settings → Project API key)
EXPO_PUBLIC_POSTHOG_API_KEY=phc_XXXXXXXXXXXXXXXXXXXX

# Sentry — EAS Build (subida de source maps en Gradle; mismo patrón que GOOGLE_SERVICES_JSON):
# eas env:create production --name SENTRY_AUTH_TOKEN --value sntrys_xxx --type string --visibility secret --non-interactive
# Opcional en GitHub Actions (sentry-health): secret SENTRY_AUTH_TOKEN

# Google Play submit (GitHub secret GOOGLE_PLAY_SERVICE_KEY_JSON):
# JSON de Cloud Console → IAM → Service accounts → tu cuenta → Keys → Add key → JSON.
# No uses google-services.json (Firebase). El workflow valida type/private_key/client_email.

# App Store Connect submit (iOS): la API key queda en EAS tras el primer `eas submit` / `--auto-submit`.
# En GitHub Actions solo hace falta EXPO_TOKEN; no añadas secrets ASC_* salvo que quieras una copia propia.

# Android FCM — solo EAS Build (no commitear google-services.json; ver TASKS.md)
# eas env:create --name GOOGLE_SERVICES_JSON --type file --value ./google-services.json --environment production --visibility secret

# Edge Function cron auth — solo CI/CD (GitHub Actions secret, no va al bundle)
# Debe coincidir con CRON_SECRET en Supabase Edge Functions y app.cron_secret en Postgres.
# EDGE_CRON_SECRET=your_random_secret_here
